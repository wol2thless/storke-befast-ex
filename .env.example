# =============================================================
# Stroke-BEFAST Application — ไฟล์ตัวอย่าง Environment Variables
# =============================================================
# วิธีใช้: คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าตามข้อมูลของ รพ. ท่าน
#   cp .env.example .env
# =============================================================


# -------------------------------------------------------------
# [ต้องแก้ไข] การเชื่อมต่อฐานข้อมูล MySQL
# -------------------------------------------------------------
NUXT_DB_HOST=localhost
# port ปกติของ MySQL บน Linux server คือ 3306
# หากใช้ MAMP (macOS) ให้ใช้ 8889
NUXT_DB_PORT=3306
NUXT_DB_USER=stroke_user
NUXT_DB_PASS=your_secure_password_here
NUXT_DB_NAME=stroke


# -------------------------------------------------------------
# [ต้องแก้ไข] URL ของ Application
# -------------------------------------------------------------
# ชื่อ path สำหรับ Nginx เช่น ถ้าเข้าผ่าน http://server/stroke ให้ใส่ /stroke
# ถ้าเป็น root ให้ว่างไว้
NUXT_PUBLIC_BASE_PATH=

# URL ลิงก์คู่มือการใช้งาน (สำหรับแสดงในแอป, ถ้าไม่มีให้ว่างไว้)
NUXT_PUBLIC_MANUAL_URL=

# URL ลิงก์คู่มือผู้ดูแลระบบ (สำหรับแสดงในแอป, ถ้าไม่มีให้ว่างไว้)
NUXT_PUBLIC_ADMIN_MANUAL_URL=

# URL แบบประเมิน (สำหรับแสดงในแอป, ถ้าไม่มีให้ว่างไว้)
NUXT_PUBLIC_ASSESSMENT_FORM_URL=


# -------------------------------------------------------------
# [แก้ไขได้] API ระบบนัดหมาย HIS (ถ้ามี)
# -------------------------------------------------------------
# ถ้า รพ. มี HIS API สำหรับดึงข้อมูลนัดหมาย ให้ระบุ URL ที่นี่
# ถ้าไม่มี ให้ว่างไว้ (ระบบจะซ่อนฟีเจอร์นัดหมายให้อัตโนมัติ)
NUXT_APPOINTMENT_API_URL=


# =============================================================
# !! ห้ามเปลี่ยนแปลงค่าด้านล่างนี้ !!
# ค่าเหล่านี้เป็นค่าของระบบ ThaiD กลาง ที่ออกแบบมาให้ใช้ร่วมกัน
# =============================================================
NUXT_PUBLIC_THAID_CLIENT_ID=NjZrZlpoZTdVM2xUSXA0dXZ2YVF0WmIyam1HVnJUcXU
NUXT_THAID_API_URL=https://hatyaihospital.go.th/ThaiD/api-ext/
